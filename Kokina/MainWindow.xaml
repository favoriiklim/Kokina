<Window x:Class="KokinaWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kokina" Height="450" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        Loaded="Window_Loaded" MouseLeftButtonDown="Window_MouseLeftButtonDown" MouseRightButtonDown="Window_MouseRightButtonDown">

    <Window.Resources>
        <RadialGradientBrush x:Key="BerryBrush3D" GradientOrigin="0.2,0.2" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
            <GradientStop Color="#FFFF9999" Offset="0" />
            <GradientStop Color="#FFFF0000" Offset="0.5" />
            <GradientStop Color="#FF800000" Offset="1" />
        </RadialGradientBrush>

        <SolidColorBrush x:Key="DarkBerryBrush" Color="#8B0000"/>

        <LinearGradientBrush x:Key="StemGreen" StartPoint="0.5,1" EndPoint="0.5,0">
            <GradientStop Color="#003300" Offset="0"/>
            <GradientStop Color="#556B2F" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="LeafLive" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#228B22" Offset="0.2"/>
            <GradientStop Color="#32CD32" Offset="1"/>
        </LinearGradientBrush>

        <Storyboard x:Key="UltraBloom">
            <DoubleAnimation Storyboard.TargetName="MasterScale" Storyboard.TargetProperty="ScaleX"
                             From="0" To="1" Duration="0:0:1.2">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="2" Springiness="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="MasterScale" Storyboard.TargetProperty="ScaleY"
                             From="0" To="1" Duration="0:0:1.2">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="2" Springiness="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="MainGrid" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="MainGrid" Width="380" Height="450" VerticalAlignment="Bottom" HorizontalAlignment="Center" RenderTransformOrigin="0.5, 1">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="MasterScale" ScaleX="1" ScaleY="1"/>
        </Grid.RenderTransform>

        <Canvas Margin="40,50,0,0">
            <Path Fill="#1A451A" Data="M 150,400 C 100,350 50,250 80,150 C 120,200 140,300 150,400 Z" Opacity="0.8" Canvas.Left="10" Canvas.Top="-10"/>
            <Path Fill="#1A451A" Data="M 160,400 C 210,350 300,250 280,150 C 240,200 200,300 160,400 Z" Opacity="0.8" Canvas.Left="-17.067" Canvas.Top="-10"/>
            <Path Fill="#2E5C2E" Data="M 155,380 C 120,300 100,200 120,100 C 150,180 160,300 155,380 Z"/>

            <Path Fill="#006400" Data="M 100,350 C 80,300 60,280 50,250 C 90,280 110,320 100,350 Z" HorizontalAlignment="Left" Canvas.Left="47.451" VerticalAlignment="Center"/>
            <Path Fill="#006400" Data="M 250,350 C 280,300 300,280 320,250 C 270,280 240,320 250,350 Z" HorizontalAlignment="Left" Canvas.Left="-100.267" VerticalAlignment="Top" Canvas.Top="15"/>
        </Canvas>

        <Canvas x:Name="LeafLayer" />

        <Canvas>
            <Ellipse Width="20" Height="20" Fill="{StaticResource DarkBerryBrush}" Canvas.Left="74" Canvas.Top="210"/>
            <Ellipse Width="18" Height="18" Fill="{StaticResource DarkBerryBrush}" Canvas.Left="66" Canvas.Top="191"/>
            <Ellipse Width="22" Height="22" Fill="{StaticResource DarkBerryBrush}" Canvas.Left="84" Canvas.Top="198"/>

            <Ellipse Width="20" Height="20" Fill="{StaticResource DarkBerryBrush}" Canvas.Left="302" Canvas.Top="198"/>
            <Ellipse Width="22" Height="22" Fill="{StaticResource DarkBerryBrush}" Canvas.Left="280" Canvas.Top="200"/>

            <Ellipse Width="24" Height="25" Fill="{StaticResource DarkBerryBrush}" Canvas.Left="178" Canvas.Top="118"/>
            <Ellipse Width="25" Height="25" Fill="{StaticResource DarkBerryBrush}" Canvas.Left="178" Canvas.Top="175"/>
        </Canvas>

        <Path x:Name="Branches"
      Stroke="#8B4513" StrokeThickness="4" StrokeEndLineCap="Round" Margin="20,0,0,0">

            <Path.Data>
                <GeometryGroup>
                    <PathGeometry Figures="M 170,420 C 170,300 170,200 170,80" />
                    <PathGeometry Figures="M 170,380 C 140,300 100,200 80,120" />
                    <PathGeometry Figures="M 170,350 C 120,300 80,250 50,180" />
                    <PathGeometry Figures="M 170,380 C 200,300 240,200 260,120" />
                    <PathGeometry Figures="M 170,350 C 220,300 260,250 300,180" />
                </GeometryGroup>
            </Path.Data>
        </Path>

